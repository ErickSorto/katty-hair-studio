GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_OWNER_EMAIL=kattyhairstudio@gmail.com
# Localhost can use a developer Gmail here. Local tokens, calendars, bookings, and
# notifications are isolated from production when running `next dev`.
# Generate with: openssl rand -base64 32
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=

# Supabase server access. Use the project URL and a server-only secret key.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SITE_URL=http://localhost:3000
# Temporary server-only guard for the calendar provisioning endpoint.
ADMIN_SETUP_TOKEN=

# Transactional email (Resend) and SMS (Twilio). Optional until messaging is enabled.
RESEND_API_KEY=
# The From domain must be verified in Resend. The address itself does not need a mailbox.
BOOKING_EMAIL_FROM=Katty Hair Studio <appointments@kattyhairstudio.com>
# Optional override. Defaults to the salon email stored in Supabase.
BOOKING_OWNER_EMAIL=kattyhairstudio@gmail.com
# Optional internal new-booking SMS. Configure only after the owner agrees to receive it.
BOOKING_OWNER_PHONE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# For a quick trial, set TWILIO_PHONE_NUMBER. In production, use a Messaging
# Service instead; when both are present, the Messaging Service takes priority.
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
